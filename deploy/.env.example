# Copy to deploy/.env on the server and fill in real values.
# NEVER commit deploy/.env to git.

PUBLIC_HOST=31.97.116.169

API_PORT=9001
BUSINESS_PORT=9002
CUSTOMER_PORT=9003
ADMIN_PORT=9004

API_BASE_URL=http://31.97.116.169:9001
CustomerApp__BaseUrl=http://31.97.116.169:9003
Paystack__CallbackUrl=http://31.97.116.169:9002/subscription

# PostgreSQL (Aiven or self-hosted)
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=ArkifiHub.Business;Username=YOUR_USER;Password=YOUR_PASSWORD;Pooling=true;TrustServerCertificate=True

# Generate a long random string (32+ chars)
Jwt__Secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32_CHARS_MIN

# 32-character encryption key for payment config
EncryptionSettings__Key=CHANGE_ME_32_CHAR_ENCRYPTION_KEY_

Paystack__SecretKey=sk_live_or_test_key

SmtpSettings__Server=smtppro.zoho.com
SmtpSettings__Port=587
SmtpSettings__SenderName=ArkifiStay
SmtpSettings__SenderEmail=info@yourdomain.com
SmtpSettings__Password=your_smtp_password
